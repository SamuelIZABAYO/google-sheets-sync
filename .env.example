# Runtime environment
NODE_ENV=development

# Fastify bind host (0.0.0.0 for containers)
HOST=0.0.0.0

# Service port used by API and container
PORT=3001

# Public domain used by Caddy reverse proxy
APP_DOMAIN=app.automationglass.com

# SQLite database location inside container/host
DATABASE_PATH=/data/app.db

# JWT signing secret (min 32 chars)
JWT_SECRET=

# JWT token lifetime
JWT_EXPIRES_IN=7d

# Upstash Redis REST endpoint URL (optional; enables Redis-backed OAuth state)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST auth token (optional)
UPSTASH_REDIS_REST_TOKEN=

# Redis list key used for sync-run queue messages
SYNC_QUEUE_KEY=sync-jobs

# Number of background workers polling queue concurrently
SYNC_WORKER_CONCURRENCY=2

# BRPOP long-poll timeout per worker in seconds
SYNC_WORKER_POLL_TIMEOUT_SEC=15

# Google OAuth2 client ID
GOOGLE_CLIENT_ID=

# Google OAuth2 client secret
GOOGLE_CLIENT_SECRET=

# OAuth scopes requested from Google
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/spreadsheets.readonly

# Optional explicit callback URL (defaults to https://APP_DOMAIN/auth/google/callback)
GOOGLE_OAUTH_REDIRECT_URI=

# 32-byte token encryption key (raw 32-char text, 64-char hex, or base64)
TOKEN_ENCRYPTION_KEY=
